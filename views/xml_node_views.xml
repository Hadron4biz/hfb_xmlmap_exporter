<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<!-- ✅ FORM VIEW -->
	<record id="view_xml_export_node_form_edit" model="ir.ui.view">
		<field name="name">xml.export.node.form.edit</field>
		<field name="model">xml.export.node</field>
		<field name="arch" type="xml">
			<form string="Edytuj węzeł XML">
				<sheet>
					<group string="Definicja węzła">
						<field name="template_id" readonly="1"/>
						<field name="parent_id"/>
						<field name="xpath" readonly="1"/>
						<field name="name"/>
						<field name="node_kind" readonly="0"/>
						<field name="type_id" domain="[('template_id', '=', template_id)]" context="{'default_template_id': template_id}"/>
						<field name="xsd_type_name" readonly="1"/>
						<field name="xsd_enumeration" readonly="1" widget="text"/>
					</group>

					<group string="Źródło wartości" col="2">
						<!-- Wyrażenie warunkowego przetwarzania -->
						<field name="condition_expr" />
						<field name="value_source"/>
						<!-- Pole Odoo -->
						<group invisible="value_source != 'field'">
							<field name="src_model_id" readonly="1"/>
							<field name="src_field_id" domain="[('model_id', '=', src_model_id)]"/>
							<field name="src_field_type" readonly="1"/>
							<field name="loop_model_id" />
							<field name="loop_rel_field_id" domain="[('model_id','=',loop_model_id)]"/>							
							<field name="src_model_field_id"/>
						</group>

						<!-- Ścieżka relacji -->
						<group invisible="value_source != 'related'">
							<field name="src_rel_path" placeholder="np. partner_id.vat lub move_id.invoice_date"/>
						</group>

						<!-- Stała -->
						<field name="value_fixed"
							   invisible="value_source != 'constant'"
							   placeholder="Wartość stała (np. 'PL')"/>

						<!-- Wyrażenie -->
						<field name="value_expr"
							   invisible="value_source != 'expression'"
							   placeholder="np. record.amount_total or '0.00'"/>

						<!-- Kontekst -->
						<group invisible="value_source != 'context'">
							<field name="src_rel_path" placeholder="np. company_id, user_id, date_today"/>
						</group>

						<!-- Sekwencja -->
						<group invisible="value_source != 'sequence'">
							<field name="value_sequence_name" placeholder="Nazwa sekwencji Odoo"/>
						</group>

						<!-- Załącznik -->
						<group invisible="value_source != 'attachment_b64'">
							<field name="value_attachment_field" placeholder="Pole binarne (base64)"/>
						</group>

						<!-- Literal XML -->
						<group invisible="value_source != 'literal_xml'">
							<field name="value_literal" widget="text" placeholder="Fragment XML bez escapowania"/>
						</group>
					</group>

					<group string="Zaawansowane" colspan="2">
						<field name="xsd_min_occurs" readonly="1"/>
						<field name="xsd_max_occurs" readonly="1"/>
						<field name="xsd_nillable" readonly="1"/>
					</group>
				</sheet>

				<footer>
					<button string="Zapisz" special="save" class="btn-primary"/>
					<button string="Anuluj" special="cancel" class="btn-secondary"/>
				</footer>
			</form>
		</field>
	</record>

	<record id="action_xml_export_node_form" model="ir.actions.act_window">
		<field name="name">Edytuj węzeł XML</field>
		<field name="res_model">xml.export.node</field>
		<field name="view_mode">form</field>
		<field name="view_id" ref="hfb_xmlmap_exporter.view_xml_export_node_form"/>
		<field name="target">new</field>
	</record>

    <!-- ✅ LIST VIEW -->
    <record id="view_xml_export_node_list" model="ir.ui.view">
        <field name="name">xml.export.node.list</field>
        <field name="model">xml.export.node</field>
        <field name="arch" type="xml">
            <list string="Węzły XML"
                  default_order="sequence"
                  editable="bottom"
				  decoration-success="state == 'validated'"
				  decoration-danger="state == 'error'"
                  create="true"
                  delete="true">
				<field name="state" optional="hide" />
                <field name="sequence" optional="hide"/>
                <field name="parent_id" optional="hide"/>
                <field name="xpath" widget="badge"/>
                <field name="name"/>
                <field name="xsd_type_name"/>
                <field name="xsd_type_kind" optional="hide"/>
                <field name="xsd_min_occurs" optional="hide"/>
                <field name="xsd_max_occurs" optional="hide"/>
                <field name="xsd_nillable" optional="hide"/>
                <field name="src_model_id"/>
                <field name="src_field_id"/>
                <field name="src_rel_path"/>
                <field name="value_constant"/>
                <field name="value_expr" optional="hide"/>
				<button name="action_open_node_form"
					type="object"
					icon="fa-pencil"
					title="Edytuj węzeł"
					class="btn-link"/>
            </list>
        </field>
    </record>

	<!-- ✅ FORM VIEW -->
    <record id="view_xml_export_node_form" model="ir.ui.view">
        <field name="name">xml.export.node.form</field>
        <field name="model">xml.export.node</field>
        <field name="arch" type="xml">
            <form string="Węzeł XML">
                <sheet>
                    <group>
                        <group string="Identyfikacja">
                            <field name="template_id" readonly="1"/>
                            <field name="parent_id"/>
                            <field name="sequence"/>
                            <field name="node_kind" readonly="0"/>
                            <field name="name"/>
                            <field name="ns_prefix" optional="hide"/>
                            <field name="namespace_uri" optional="hide"/>
                        </group>
                        <group string="Typ i kardynalność (XSD)">
							<field name="xpath" />
							<field name="type_id" domain="[('template_id', '=', template_id)]" context="{'default_template_id': template_id}"/>
                            <field name="xsd_type_name"/>
                            <field name="xsd_type_kind"/>
                            <field name="xsd_min_occurs"/>
                            <field name="xsd_max_occurs"/>
                            <field name="xsd_nillable"/>
                            <field name="xsd_default"/>
                            <field name="xsd_fixed"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Źródło wartości">
							<group>
								<group string="Źródło Odoo">
									<field name="condition_expr" />
									<field name="src_model_id" />
									<field name="src_field_id" domain="[('model_id','=',src_model_id)]" />
									<field name="loop_model_id" />
									<field name="loop_rel_field_id" domain="[('model_id','=',loop_model_id)]"/>
									<field name="src_rel_path" placeholder="partner_id.vat" />
								</group>

								<group string="Kolekcje / pętle">
									<field name="loop_mode" />
									<field name="loop_model_id" />
									<field name="loop_domain" />
									<field name="loop_order" />
									<field name="loop_limit" />
								</group>

								<group string="Alternatywne źródła">
									<field name="value_constant" placeholder="wartość stała (tekst/liczba)" />
									<field name="value_source" />
									<field name="value_expr" placeholder="wyrażenie Pythonowe (np. record.amount_total * 1.23)" />
									<field name="context_key" placeholder="klucz z kontekstu eksportu" />
								</group>
							</group>
                        </page>

                        <page string="Dokumentacja XSD">
                            <field name="xsd_documentation" nolabel="1" readonly="1"/>
                            <field name="xsd_enumeration" nolabel="1" readonly="1"/>
                        </page>

                        <page string="Uwagi / Notatki">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ✅ AKCJA I MENU (opcjonalne, np. serwisowe) -->
    <record id="action_xml_export_node" model="ir.actions.act_window">
        <field name="name">Węzły</field>
        <field name="res_model">xml.export.node</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
    </record>

    <menuitem id="menu_xml_export_node"
              name="Węzły [node]"
              parent="menu_xml_export_config"
              action="action_xml_export_node"
              sequence="55"/>

</odoo>
