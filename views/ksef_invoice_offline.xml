<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================= -->
    <!--  SZABLON FAKTURY KSeF – TRYB OFFLINE                     -->
    <!-- ========================================================= -->

    <template id="ksef_invoice_offline_document"
              inherit_id="account.report_invoice_document">

        <!-- ===================================================== -->
        <!--  NAGŁÓWEK – WYRAŹNE OZNACZENIE OFFLINE                -->
        <!-- ===================================================== -->

        <xpath expr="//div[contains(@class,'page')][1]" position="before">

            <div class="alert alert-warning"
                 style="border: 2px solid #b94a48;
                        padding: 12px;
                        margin-bottom: 16px;
                        font-size: 14px;">

                <strong>
                    FAKTURA WYSTAWIONA W TRYBIE OFFLINE – KSeF
                </strong>

                <br/>

                <span>
                    Faktura została wystawiona poza systemem KSeF
                    z powodu jego niedostępności lub zgodnie z
                    dopuszczalnym trybem offline.
                </span>

            </div>

        </xpath>

        <!-- ===================================================== -->
        <!--  BLOK INFORMACYJNY – SZCZEGÓŁY OFFLINE                -->
        <!-- ===================================================== -->

        <xpath expr="//table[contains(@class,'invoice_info')]" position="after">

            <table class="table table-sm mt16"
                   style="width: 100%; border: 1px solid #999;">
                <tbody>

                    <tr>
                        <td style="width: 30%; font-weight: bold;">
                            Tryb KSeF
                        </td>
                        <td>
                            OFFLINE
                        </td>
                    </tr>

                    <tr>
                        <td style="font-weight: bold;">
                            Rodzaj trybu OFFLINE
                        </td>
                        <td>
                            <t t-esc="o.ksef_offline_mode or '-'"/>
                        </td>
                    </tr>

                    <tr>
                        <td style="font-weight: bold;">
                            Data wystawienia
                        </td>
                        <td>
                            <t t-esc="o.invoice_date"/>
                        </td>
                    </tr>

                    <tr>
                        <td style="font-weight: bold;">
                            Numer KSeF
                        </td>
                        <td>
                            <em>
                                Brak – faktura wystawiona w trybie OFFLINE
                            </em>
                        </td>
                    </tr>

                    <tr>
                        <td style="font-weight: bold;">
                            Uzasadnienie trybu OFFLINE
                        </td>
                        <td>
                            <t t-esc="o.ksef_offline_reason or '-'"/>
                        </td>
                    </tr>

                </tbody>
            </table>

        </xpath>

        <!-- ===================================================== -->
        <!--  STOPKA – INFORMACJA PRAWNA / AUDYTOWA                -->
        <!-- ===================================================== -->

        <xpath expr="//div[contains(@class,'footer')]" position="inside">

            <div style="margin-top: 12px;
                        font-size: 10px;
                        color: #555;
                        border-top: 1px dashed #aaa;
                        padding-top: 6px;">

                <p>
                    Zgodnie z przepisami ustawy o VAT faktura wystawiona
                    w trybie OFFLINE podlega obowiązkowemu dosłaniu
                    do Krajowego Systemu e-Faktur (KSeF)
                    w ustawowym terminie.
                </p>

                <p>
                    Dokument wygenerowany automatycznie przez system Odoo
                    na podstawie danych księgowych.
                </p>

            </div>

        </xpath>

    </template>

</odoo>
