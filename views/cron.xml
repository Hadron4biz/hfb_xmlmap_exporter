<odoo>
    <data noupdate="1">
        <!-- Cron do przetwarzania kolejki KSeF -->
        <record id="cron_process_ksef_queue" model="ir.cron">
            <field name="name">🚩 Provider KSeF: Communication Queue</field>
            <field name="model_id" ref="model_communication_log"/>
            <field name="state">code</field>
            <field name="code">model._cron_process_ksef_queue()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="False"/>
        </record>
    </data>

    <data noupdate="1">
        <!-- Cron do planowania importu listy faktur KSeF -->
        <record id="ir_cron_ksef_schedule_import_list" model="ir.cron">
            <field name="name">🚩 Provider KSeF: Schedule Import List</field>
            <field name="active">False</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>  <!-- Uruchamiaj co godzinę -->
            <field name="model_id" ref="model_communication_log"/>
            <field name="state">code</field>
            <field name="code">model._cron_ksef_schedule_import_list()</field>
            <field name="priority">10</field>
        </record>
    </data>

    <data noupdate="1">
        <!-- Cron do sprawdzania dostępności środowiska KSeF -->
        <record id="ir_cron_ksef_environment_check" model="ir.cron">
            <field name="name">⚠️  Provider KSeF – Environment Health Check</field>
            <field name="active">False</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>  <!-- Uruchamiaj co godzinę -->
            <field name="model_id" ref="model_communication_log"/>
            <field name="state">code</field>
            <field name="code">model.cron_ksef_environment_check()</field>
            <field name="priority">10</field>
        </record>
    </data>

    <data noupdate="1">
        <!-- Cron do Sporządzania raportu okresowego KSeF -->
        <record id="ir_cron_ksef_daily_report" model="ir.cron">
            <field name="name">⚠️  Provider KSeF – Communication Report</field>
            <field name="active">False</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>  <!-- Uruchamiaj co godzinę -->
            <field name="model_id" ref="model_communication_log"/>
            <field name="state">code</field>
            <field name="code">model.cron_ksef_daily_report()</field>
            <field name="priority">10</field>
        </record>
    </data>

    <data noupdate="1">
        <!-- Cron do sprawdzania zadań KSeF -->
        <record id="ir_cron_ksef_monitor_failures" model="ir.cron">
            <field name="name">⚠️  Provider KSeF – Monitor Health Check</field>
            <field name="active">False</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>  <!-- Uruchamiaj co godzinę -->
            <field name="model_id" ref="model_communication_log"/>
            <field name="state">code</field>
            <field name="code">model.cron_ksef_monitor_failures()</field>
            <field name="priority">10</field>
        </record>
    </data>



</odoo>
