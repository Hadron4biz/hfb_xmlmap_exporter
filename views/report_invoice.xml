<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_document_qr" inherit_id="account.report_invoice_document">
        <xpath expr="//div[hasclass('footer')]" position="before">

            <t t-if="o.ksef_qr_code_verification">
                <div class="row mt-4" style="page-break-inside: avoid;">
                    <div class="col-12">
                        <h4 style="border-bottom: 1px solid #ddd; padding-bottom: 5px;">
                            Kody weryfikujące KSeF
                        </h4>
                    </div>

                    <!-- KOD I -->
                    <div class="col-6 text-center">
                        <img t-att-src="'data:image/png;base64,' + o.ksef_qr_code_verification"
                             alt="KOD I"
                             style="width: 150px; height: 150px;"/>
                        <p style="margin-top: 5px; font-weight: bold;">
                            <t t-esc="o.ksef_qr_label or ''"/>
                        </p>
                    </div>

                    <!-- KOD II (offline) -->
                    <t t-if="o.ksef_qr_code_certificate">
                        <div class="col-6 text-center">
                            <img t-att-src="'data:image/png;base64,' + o.ksef_qr_code_certificate"
                                 alt="KOD II"
                                 style="width: 150px; height: 150px;"/>
                            <p style="margin-top: 5px; font-weight: bold;">
                                CERTYFIKAT
                            </p>
                        </div>
                    </t>

                    <div class="col-12 mt-2" style="font-size: 10px; color: #666;">
                        <p style="margin: 0;">
                            Zeskanuj kod QR, aby przejść do weryfikacji faktury w systemie KSeF.
                        </p>

                        <!-- Opcjonalne pokazanie URL tekstowo (czasem przydatne) -->
                        <t t-if="getattr(o, 'ksef_qr_invoice_url', False)">
                            <p style="margin: 2px 0 0 0;">
                                <span>URL:</span>
                                <span t-esc="o.ksef_qr_invoice_url"/>
                            </p>
                        </t>
                    </div>
                </div>
            </t>

        </xpath>
    </template>
</odoo>
