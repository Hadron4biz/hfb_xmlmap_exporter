<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<record id="view_xml_import_json_wizard" model="ir.ui.view">
		<field name="name">xml.template.import.json.wizard.form</field>
		<field name="model">xml.template.import_json.wizard</field>
		<field name="arch" type="xml">
			<form string="Import szablonu XML z pliku JSON">
				<group>
					<field name="json_file"/>
					<field name="filename" readonly="1"/>
					<!--field name="template_name"/-->
					<!--field name="overwrite_existing"/-->
				</group>
				<footer>
					<button string="Importuj"
							name="action_import_json"
							type="object"
							class="btn-primary"/>
					<button string="Anuluj" special="cancel"/>
				</footer>
			</form>
		</field>
	</record>

</odoo>
