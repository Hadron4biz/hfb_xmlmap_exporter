<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- FORM VIEW: Provider PowerOffice -->
    <record id="view_communication_provider_poweroffice_form" model="ir.ui.view">
        <field name="name">communication.provider.poweroffice.form</field>
        <field name="model">communication.provider.poweroffice</field>
        <field name="inherit_id" ref="hfb_xmlmap_exporter.view_communication_provider_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="inside">

                <group string="PowerOffice API">
                    <field name="api_key"/>
                    <field name="client_id"/>
                    <field name="client_secret"/>
                    <field name="base_url"/>
                </group>

            </xpath>

        </field>
    </record>

    <!-- ACTION -->
    <record id="action_communication_provider_poweroffice" model="ir.actions.act_window">
        <field name="name">Provider PowerOffice</field>
        <field name="res_model">communication.provider.poweroffice</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_communication_provider_poweroffice"
              name="Provider PowerOffice"
              parent="hfb_xmlmap_exporter.menu_communication_providers_root"
              action="action_communication_provider_poweroffice"
              sequence="50"/>

</odoo>
