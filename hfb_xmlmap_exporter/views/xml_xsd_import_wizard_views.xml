<odoo>
    <record id="view_xml_xsd_import_wizard_form" model="ir.ui.view">
        <field name="name">xml.xsd.import.wizard.form</field>
        <field name="model">xml.xsd.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import plików XSD (import/include)">
                <sheet>
                    <group>
                        <field name="template_id" readonly="1"/>
                    </group>
                    <field name="import_line_ids" nolabel="1">
                        <list>
                            <field name="download"/>
                            <field name="url"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button string="Pobierz i zaimportuj"
                            name="action_confirm"
                            type="object"
                            class="btn-primary"/>
                    <button string="Anuluj" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
