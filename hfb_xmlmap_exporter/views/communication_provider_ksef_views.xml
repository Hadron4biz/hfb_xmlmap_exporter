<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<record id="view_communication_provider_ksef_form" model="ir.ui.view">
		<field name="name">communication.provider.ksef.form</field>
		<field name="model">communication.provider.ksef</field>
		<field name="arch" type="xml">
			<form string="Konfiguracja KSeF">
				<header>

					<!-- Status aktywności -->
					<field name="active" widget="boolean_toggle" 
						   class="oe_edit_only" />
				</header>
				
				<sheet>
					<!-- Podstawowa konfiguracja -->
					<group>
						<group string="Podstawowe">
							<field name="name"/>
							<field name="code"/>
							<field name="active"/>
						</group>
						
						<group string="Środowisko i autoryzacja">
							<field name="base_url" />
							<field name="qr_code_url" />
							<field name="environment" invisible="1"/>
							<field name="api_backend"/>
							<field name="auth_type"/>
							<field name="jar_directory" />
						</group>
					</group>
					
					<!-- Opis -->
					<group>
						<group string="Opis">
							<field name="description" widget="textarea"/>
						</group>
					</group>
					
					<!-- Notatnik z konfiguracją specyficzną -->
					<notebook>
						<!-- KARTA 1: JET API Token -->
						<page string="JET API Token" attrs="{ 'invisible': [('auth_type', '!=', 'jet_token')]}">
							<group string="Konfiguracja JET API">
								<field name="jet_api_key" 
									   placeholder="Wpisz 32-znakowy klucz hex"/>
								
								<field name="jet_api_token" 
									   placeholder="Wklej token JET API"/>
								
							</group>
							
							<group string="Informacje">
								<div class="alert alert-info">
									<strong>Jak uzyskać klucz JET API:</strong><br/>
									1. Zaloguj się na Portal Podatkowy<br/>
									2. Przejdź do: e-Usługi → Dostęp do usług API → KSeF<br/>
									3. Wygeneruj nowy klucz API<br/>
									4. Skopiuj klucz i token do powyższych pól
								</div>
							</group>
						</page>
						
						<!-- KARTA 2: Certyfikat -->
						<page string="Certyfikat" attrs="{ 'invisible': [('auth_type', '!=', 'certificate')]}">
							<group string="Konfiguracja sesji NIP">
								<field name="company_nip" readonly="0"/>
								
							</group>
							<group>
								<group string="Konfiguracja certyfikatu">
									<field name="auth_keystore_p12" force_save="1" />
									<field name="auth_keystore_password" 
										placeholder="Hasło do certyfikatu Autoryzacji" 
										password="1"/>

									<field name="sign_keystore_p12" force_save="1" />
                                    <field name="sign_keystore_password" 
										placeholder="Hasło do certyfikatu Podpisywania" 
										password="1"/>

								</group>
							</group>
							<group>
								<group>
									<field name="mf_certificate_pem" />
								</group>
							</group>
						</page>
						
						<!-- KARTA 3: Token sesyjny -->
						<page string="Token sesyjny" attrs="{ 'invisible': [('auth_type', '!=', 'session_token')]}">
							<group string="Konfiguracja sesji NIP">
								<field name="company_nip" readonly="0"/>
								
							</group>
							
							<group string="Informacje">
								<div class="alert alert-info">
									<strong>Jak uzyskać token sesyjny:</strong><br/>
									1. Zaloguj się do KSeF przez NIP<br/>
									2. Wygeneruj token sesyjny w panelu API<br/>
									3. Token jest ważny zwykle 1-24 godziny<br/>
									4. Wklej token do powyższego pola
								</div>
							</group>
						</page>
						
						<!-- KARTA 4: Opcje -->
						<page string="Opcje">
							<group>
								<group string="Powiadomienia dla zadań CRON">
									<field name="alert_contact_id" placeholder="Wskaż dla kogo wysyłane będą powiadomienia"/>
									<field name="alert_email" />
									<field name="alert_phone" />
								</group>

								<group string="Opcje wysyłki">
									<field name="validate_before_send"/>
									<field name="auto_check_status"/>
									<field name="status_check_delay"/>
								</group>
								
								<group string="Debugowanie">
									<field name="qr_report_template_id" />
									<field name="debug_mode"/>
								</group>
							</group>
						</page>
						
						<!-- KARTA 6: Sesje KSeF v2 (SUPER PROSTA WERSJA) -->
						<page string="Sesja KSeF v2">
							<group string="Informacje o sesji">
								<div class="alert alert-info">
									<strong>🔧 Sesje KSeF v2 - zarządzane automatycznie</strong><br/><br/>
									System automatycznie tworzy i zarządza sesjami API.<br/>
									Przy wysyłce faktury: 
									<ol>
										<li>System sprawdza czy sesja jest aktywna</li>
										<li>Jeśli nie - tworzy nową sesję</li>
										<li>Wysyła fakturę przez sesję</li>
										<li>Przechowuje informacje o sesji (tylko do monitorowania)</li>
									</ol>
								</div>
							</group>
							
						</page>

						<!-- KARTA 7: Konfiguracja importów  -->
						<page string="Import Configuration" name="import_config">
							<group string="Automatic Import Settings">
								<field name="import_template_id" />
								<field name="import_enabled"/>
								<field name="import_frequency_hours"/>
								<field name="import_last_success_date" readonly="1"/>
								<field name="import_next_schedule" readonly="1"/>
								<field name="import_days_back"/>
								<field name="import_subject_type"/>
								<field name="import_page_size"/>
								<field name="import_max_pages"/>
							</group>
						</page>

					</notebook>
				</sheet>
			</form>
		</field>
	</record>

</odoo>
