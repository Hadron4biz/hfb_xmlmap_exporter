<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- FORM VIEW: Provider Peppol -->
    <record id="view_communication_provider_peppol_form" model="ir.ui.view">
        <field name="name">communication.provider.peppol.form</field>
        <field name="model">communication.provider.peppol</field>
        <field name="inherit_id" ref="hfb_xmlmap_exporter.view_communication_provider_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="inside">

                <group string="Peppol / eDelivery AS4">
                    <field name="endpoint_url"/>
                    <field name="as4_certificate_id"/>
                    <field name="participant_id"/>
                </group>

            </xpath>

        </field>
    </record>

    <!-- ACTION -->
    <record id="action_communication_provider_peppol" model="ir.actions.act_window">
        <field name="name">Provider Peppol</field>
        <field name="res_model">communication.provider.peppol</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_communication_provider_peppol"
              name="Provider Peppol"
              parent="hfb_xmlmap_exporter.menu_communication_providers_root"
              action="action_communication_provider_peppol"
              sequence="40"/>

</odoo>
