<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<!-- LISTA: Szablony XML -->
	<record id="view_xml_export_template_tree" model="ir.ui.view">
		<field name="name">xml.export.template.tree</field>
		<field name="model">xml.export.template</field>
		<field name="arch" type="xml">
			<tree string="Szablony XML" >
				<field name="state" invisible="1" />
				<field name="name"/>
				<field name="model_id"/>
				<field name="doc_direction"/>
				<field name="root_tag"/>
				<field name="ns_prefix"/>
				<field name="namespace"/>
				<field name="xsd_attachment_id"/>
				<field name="validate_on_export"/>
				<field name="active"/>
			</tree>
		</field>
	</record>

	<!-- WYSZUKIWANIE: Szablony XML -->
	<record id="view_xml_export_template_search" model="ir.ui.view">
		<field name="name">xml.export.template.search</field>
		<field name="model">xml.export.template</field>
		<field name="arch" type="xml">
			<search string="Szukaj szablonów">
				<field name="name"/>
				<field name="model_id"/>
				<field name="doc_direction"/>
				<field name="root_tag"/>
				<filter string="Aktywne" name="active_true" domain="[('active','=',True)]"/>
				<filter string="Nieaktywne" name="active_false" domain="[('active','=',False)]"/>
			</search>
		</field>
	</record>

	<!-- AKCJA DO FORMULARZA Szablon XML: Auto-układ sekwencji -->
	<record id="action_auto_sequence_nodes" model="ir.actions.server">
		<field name="name">Auto-układ sekwencji</field>
		<field name="model_id" ref="model_xml_export_template"/>
		<field name="state">code</field>
		<field name="code">
			if records:
				records.auto_sequence_nodes()
		</field>
	</record>

	<!-- FORMULARZ: Szablon XML -->
	<record id="view_xml_export_template_form" model="ir.ui.view">
		<field name="name">xml.export.template.form</field>
		<field name="model">xml.export.template</field>
		<field name="arch" type="xml">
			<form string="Szablon eksportu XML">
				<header>
					<field name="state" invisible="1"/>
					<field name="xsd_attachment_id" invisible="1"/>

					<button name="action_open_xsd_upload_wizard"
							type="object"
							string="Wgraj schemę (XSD)"
							class="oe_highlight"
							invisible="xsd_attachment_id != False"/>

					<button name="action_reset_nodes"
							type="object"
							string="Wyczyść węzły"
							class="btn-danger"
							confirm="Czy na pewno chcesz usunąć wszystkie węzły XML?"
							invisible="xsd_attachment_id == False"/>

					<button name="action_import_from_schema"
							type="object"
							string="Import struktury z XSD"
							class="btn-primary"
							icon="fa-sitemap"
							invisible="xsd_attachment_id == False"
							confirm="Czy na pewno chcesz zaimportować strukturę z XSD? Istniejące węzły zostaną usunięte."/>

					<button name="action_import_xsd_types"
							type="object"
							string="Import typów XSD"
							class="btn-secondary"
							icon="fa-database"
							invisible="xsd_attachment_id == False or xsd_type_count > 0"/>

					<button name="action_validate_template_full"
							type="object"
							string="Walidacja pełna"
							class="oe_highlight"
							invisible="node_count == 0"/>

					<button name="auto_sequence_nodes" 
							string="Auto-układ sekwencji" 
							type="object" 
							class="btn-primary"
							invisible="node_count == 0"/>

					<button name="action_export_json"
							type="object"
							string="Eksportuj JSON"
							class="oe_highlight"
							icon="fa-download"
							groups="base.group_system"
							/>
				</header>
				<sheet>

					<div class="oe_button_box" name="button_box">
						<!-- przycisk typów XSD -->
						<button name="action_show_xsd_types"
								type="object"
								class="oe_stat_button"
								icon="fa-database"
								string="Typy XSD">
							<field name="xsd_type_count" widget="statinfo" string="Typy XSD"/>
						</button>

						<!-- przycisk węzłów XML -->
						<button name="action_show_nodes"
								type="object"
								class="oe_stat_button"
								icon="fa-code"
								string="Węzły XML">
							<field name="node_count" widget="statinfo" string="Węzły XML"/>
						</button>
					</div>

					<div class="oe_title">
					<label for="name"/>
					<h1>
						<field name="name" placeholder="odoo-19.0-peppol-3.0-bill-1.2.3"/>
					</h1>
					</div>

					<group>
						<group string="Źródło">							
							<field name="model_id" options="{'no_open': True}" required="0"/>
							<field name="doc_direction"/>
							<field name="validate_on_export"/>
							<field name="active"/>
						</group>
						<group string="Root i namespace">
							<field name="root_tag"/>
							<field name="ns_prefix"/>
							<field name="namespace"/>
						</group>
						<group string="Obsługiwany przez Dostawcę" >
							<field name="provider_id" />
						</group>

					</group>

					<group string="Schemat XSD">
					<field name="xsd_attachment_id" required="0"
							 context="{'default_res_model': 'xml.export.template'}"/>
					</group>

					<notebook>
						<page string="Węzły (XPath)">
							<field name="node_ids">
							<!-- LISTA WĘZŁÓW -->
							<tree string="Węzły (XPath)" 
								editable="bottom" 
								default_order="sequence,id"
								decoration-success="state == 'validated'"
								decoration-danger="state == 'error'"
								>
								<field name="state" invisible="1" />
								<field name="template_id" invisible="1"/>
								<field name="template_model_id" invisible="1"/>
								<field name="id" string="id" />
								<field name="sequence" string="Seq" />
								<field name="name"/>
								<field name="xpath"/>
								<field name="xsd_type_name"/>								
								<field name="node_kind" />
								<field name="xsd_type_kind"/>
								<field name="src_rel_path" />
								<button name="action_open_node_form"
									type="object"
									icon="fa-pencil"
									title="Edytuj węzeł"
									class="btn-link"/>
							</tree>

							<!-- FORMULARZ WĘZŁA -->
							<form string="Węzeł">
								<group>
								<group string="Identyfikacja">
									<field name="sequence"/>
									<field name="parent_id"/>
									<field name="template_id" invisible="1"/>
									<field name="template_model_id" invisible="1"/>
									<field name="node_kind"/>
									<field name="name" required="1"/>
									<field name="ns_prefix"/>
									<field name="namespace_uri"/>
								</group>

								<group string="XSD (informacyjnie)">
									<field name="xsd_type_name"/>
									<field name="xsd_type_kind"/>
									<field name="xsd_min_occurs"/>
									<field name="xsd_max_occurs"/>
									<field name="xsd_nillable"/>
									<field name="xsd_default"/>
									<field name="xsd_fixed"/>
								</group>
								</group>

								<group string="Źródło wartości">
								<field name="value_source"/>
								<field name="src_model_id" options="{'no_open': True}"/>
								<field name="src_field_id" options="{'no_open': True}"/>
								<field name="src_rel_path"/>
								<field name="value_constant"/>
								<field name="value_expr"/>
								<field name="context_key"/>
								</group>

								<group string="Iteracja">
								<field name="loop_mode"/>
								<field name="loop_model_id" options="{'no_open': True}"/>
								<field name="loop_rel_field_id" options="{'no_open': True}"/>
								<field name="loop_domain"/>
								<field name="loop_order"/>
								<field name="loop_limit"/>
								</group>
							</form>
							</field>
						</page>

						<page string="Typy XSD">
							<field name="xsd_type_ids" context="{'default_template_id': id}">
								<tree>
									<field name="name"/>
									<field name="category"/>
									<field name="base_type"/>
									<field name="pattern"/>
								</tree>
							</field>
							<footer>
								<button name="action_import_xsd_types"
										type="object"
										string="Importuj typy XSD"
										class="btn-secondary"
										icon="fa-database"/>
							</footer>
						</page>

						<page string="Pliki Typów XSD">
                            <field name="xsd_type_attachment_ids" context="{'default_template_id': id}" />
                                <!--tree>
                                    <field name="name"/>
                                    <field name="category"/>
                                    <field name="base_type"/>
                                    <field name="pattern"/>
                                </tree>
                            </field-->
                        </page>
					</notebook>
				</sheet>
				<div class="oe_chatter">
					<field name="message_follower_ids"/>
					<field name="message_ids"/>
				</div>
			</form>
		</field>
	</record>

</odoo>
