<odoo>
    <record id="view_ksef_connection_test_result_form" model="ir.ui.view">
        <field name="name">ksef.connection.test.result.form</field>
        <field name="model">ksef.connection.test.result</field>
        <field name="arch" type="xml">
            <form string="Wynik testu połączenia KSeF">
                <group>
                    <field name="summary" readonly="1"/>
                </group>

                <field name="step_ids" >
                    <tree string="Kroki testu" editable="top"
						decoration-success="status == 'ok'"
						decoration-danger="status == 'error'"
						decoration-muted="status == 'skipped'">
                        <field name="name"/>
                        <field name="status" />
                        <field name="detail"/>
                    </list>
                </field>

                <footer>
                    <button string="Zamknij" class="btn-primary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
