<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_communication_channel_tree" model="ir.ui.view">
        <field name="name">communication.channel.tree</field>
        <field name="model">communication.channel</field>
        <field name="arch" type="xml">
			<list>
				<field name="name"/>
				<field name="code"/>
				<field name="provider_id"/>
				<field name="active"/>
				<field name="endpoint_url"/>
			</list>
        </field>
    </record>

	<record id="view_communication_channel_form" model="ir.ui.view">
		<field name="name">communication.channel.form</field>
		<field name="model">communication.channel</field>
		<field name="arch" type="xml">
			<form string="Kanał komunikacji">
				<sheet>

					<group>
						<group string="Dane podstawowe">
							<field name="name"/>
							<field name="code"/>
							<field name="provider_id"/>
							<field name="active"/>
						</group>

						<group string="Połączenie">
							<field name="endpoint_url"/>
							<field name="encoding"/>
							<field name="content_type"/>
							<field name="compression"/>
							<field name="timeout"/>
							<field name="verify_ssl"/>
						</group>
					</group>

					<notebook>

						<page string="Autoryzacja">
							<group>
								<field name="auth_mode"/>
								<field name="auth_config"/>
							</group>
						</page>

						<page string="Logi">
							<field name="log_ids">
								<list>
									<field name="create_date"/>
									<field name="operation"/>
									<field name="status"/>
									<field name="message"/>
								</list>
							</field>
						</page>

						<page string="Konfiguracja XML">
							<group>
								<field name="template_id"/>
								<field name="xsd_attachment_id"/>
							</group>
						</page>

					</notebook>

				</sheet>

		       <div class="oe_chatter">
	                <field name="message_follower_ids"/>
	                <field name="message_ids"/>
	            </div>

			</form>
		</field>
	</record>

    <record id="action_communication_channels" model="ir.actions.act_window">
        <field name="name">Kanały komunikacji</field>
        <field name="res_model">communication.channel</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
