<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<!-- ==============================================================
		 WIDOK LIST (TREE)
		 ============================================================== -->
	<record id="view_communication_provider_tree" model="ir.ui.view">
		<field name="name">communication.provider.tree</field>
		<field name="model">communication.provider</field>
		<field name="arch" type="xml">
			<tree>
				<field name="name"/>
				<field name="code"/>
				<field name="provider_type"/>
				<field name="provider_config_id" />
				<field name="active"/>
				<field name="description"/>
			</tree>
		</field>
	</record>

	<!-- ==============================================================
		 WIDOK FORMULARZA (FORM)
		 ============================================================== -->
	<record id="view_communication_provider_form" model="ir.ui.view">
		<field name="name">communication.provider.form</field>
		<field name="model">communication.provider</field>
		<field name="arch" type="xml">
			<form string="Provider">
				<sheet>
					<header>
						<button name="provider_test"
								string="PROVIDER TEST"
								type="object"
								class="btn-secondary"
								icon="fa-check-circle" />
					</header>
					<group>
						<group>
							<field name="name"/>
							<field name="code"/>
							<field name="provider_type"/>
							
							<!-- Wyświetl model pluginu (tylko do odczytu) -->
							<field name="provider_model" readonly="1"/>
							
							<!-- Pole z dynamicznym domain -->
							<field name="provider_config_id" 
								   context="{'show_model': False}"/>

							<field name="description"/>
							<separator />
							<field name="dynamic_config_name" />
						</group>
						<group>
							<field name="trigger_type" />
							<field name="cron_id" />
							<field name="batch_time" />
							<field name="batch_size"/>
							<field name="auto_retry"/>
							<field name="retry_attempts"/>
							<field name="retry_delay"/>
                            
						</group>
					</group>
					<div class="oe_chatter">
						<field name="message_follower_ids"/>
						<field name="message_ids"/>
					</div>
				</sheet>
			</form>
		</field>
	</record>

	<!-- ==============================================================
		 AKCJA OKNA
		 ============================================================== -->
	<record id="action_communication_providers" model="ir.actions.act_window">
		<field name="name">Providerzy</field>
		<field name="res_model">communication.provider</field>
		<field name="view_mode">tree,form</field>
	</record>

</odoo>
