<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<!-- ==============================================================
		 WIDOK LIST (TREE)
		 ============================================================== -->
	<record id="view_communication_log_tree" model="ir.ui.view">
		<field name="name">communication.log.tree</field>
		<field name="model">communication.log</field>
		<field name="arch" type="xml">
			<list default_order="create_date desc" 
				decoration-muted="state=='draft'" 
				decoration-info="state in ('generated','validated','queued')" 
				decoration-it="state=='superseded'"
				decoration-warning="state=='sent'" 
				decoration-success="state=='received'" 
				decoration-danger="state=='error'"
				>
				<field name="create_date"/>
				<field name="direction" string="Kierunek" />
				<field name="operation"/>
				<field name="ksef_status"/>
				<field name="state"/>
				<field name="ksef_invoice_number"/>
				<!--field name="ksef_http_status"/-->
				<!--field name="ksef_api_status_code"/-->
			</list>
		</field>
	</record>
	<!-- ==============================================================
		 WIDOK FORMULARZA (FORM)
		 ============================================================== -->
	<record id="view_communication_log_form" model="ir.ui.view">
		<field name="name">communication.log.form</field>
		<field name="model">communication.log</field>
		<field name="arch" type="xml">
			<form string="Log komunikacji" create="false">
				<sheet>
					<header>
						<field name="file_data" invisible="1" />
						<field name="direction" invisible="1" />
						<field name="ksef_operation" invisible="1" />
						<field name="provider_type" invisible="1"/>

						<button name="action_send_manual"
								type="object"
								string="Wyślij teraz"
								class="btn-primary"
								target="current"
								invisible="not (ksef_operation != 'completed')" />

						<field name="state" widget="statusbar"
							statusbar_visible="generated,validated,queued,sent,received,error"
							statusbar_colors='{"error":"red","sent":"blue","received":"green"}' />

					</header>

					<group>
						<!-- LEWA KOLUMNA -->
						<group string="Informacje główne">
							<field name="direction" readonly="1"/>
							<field name="provider_id" readonly="1"/>
							<field name="template_id" readonly="1"/>
							<field name="create_date" readonly="1"/>
							<field name="executed_by" readonly="1"/>
						</group>

						<!-- PRAWA KOLUMNA -->
						<group string="Dokument źródłowy">
							<field name="document_model" readonly="1"/>
							<field name="document_id" readonly="1"/>
							<field name="document_ref" readonly="1"/>
							<field name="external_id" readonly="1"/>
							<field name="duration_ms" readonly="1"/>
						</group>
					</group>

					<!-- SEKCJA KSeF - POKAŻ TYLKO DLA PROVIDERA KSeF -->
					<group invisible="provider_type != 'ksef'">
						<group string="Stan KSeF">
							<field name="ksef_operation" readonly="0"/>
							<field name="ksef_next_operation" readonly="0"/>
							<field name="ksef_retry_count" readonly="1"/>
							<field name="ksef_max_retries" readonly="1"/>
							<field name="ksef_import_days_back" readonly="0" />
						</group>
						<group string="Aktualny">
							<field name="ksef_invoice_number" invisible="not ksef_invoice_number"/>
							<field name="ksef_reference_number" />
							<field name="invoice_hash" readonly="1" />
							<field name="is_processing" invisible="1"/>
							<field name="processing_lock_until" readonly="1"/>
							<field name="ksef_last_execution" readonly="1"/>
							<field name="ksef_next_execution" readonly="1"/>
						</group>
						<field name="ksef_status" widget="statusbar" />
					</group>

					<!-- SEKCJA DANYCH -->
					<notebook>

						<page string="Dane techniczne KSeF">
							<group>
								<group string="Identyfikatory Tokenów i Sesji" >
									<field name="ksef_session_token" readonly="1"/>
									<field name="ksef_access_token" readonly="1"/>
									<field name="ksef_reference_number" readonly="1"/>
									<field name="ksef_invoice_number" readonly="1"/>
									<field name="ksef_sent_datetime" readonly="1"/>

									<separator />

									<field name="ksef_http_status" readonly="1"/>
									<field name="ksef_api_status_code" readonly="1"/>
									<field name="ksef_api_status_message" readonly="1"/>
								</group>

								<group string="Dane kryptograficzne" invisible="1" >
									<field name="ksef_session_key" invisible="1" password="True"/>
									<field name="ksef_session_iv" invisible="1" password="True"/>
								</group>
							</group>
						</page>
						
						<page string="Pliki">
							<group>
								<field name="file_name"/>
								<field name="file_size"/>
								<field name="file_data" filename="file_name" widget="binary"/>
							</group>
						</page>
						
						<!-- Zakładka Payload tylko dla KSeF -->
						<page string="Payload" invisible="provider_type != 'ksef'">
							<group>
								<label string="Request JSON" for="payload_request" />
								<field name="payload_request" widget="textarea" nolabel="1" readonly="1" style="height: 200px;" />
							</group>
							<group>
								<label string="Response JSON" for="payload_response" />
								<field name="payload_response" widget="textarea" nolabel="1" readonly="1" style="height: 200px;" />
							</group>
							<group>
								<label string="Kontekst wykonania" for="payload_context" />
								<field name="payload_context" widget="textarea" nolabel="1" readonly="1" style="height: 200px;" />
							</group>
							<group>
								<label string="Session Runtime (pełny kontekst)" for="session_runtime" />
								<field name="session_runtime" widget="textarea" nolabel="1" readonly="1" style="height: 300px;" />
							</group>
						</page>
						
						<page string="Zaawansowane">
							<group>
								<field name="validated"/>
								<field name="validation_message" widget="textarea"/>
								<field name="provider_status"/>
								<field name="provider_message" widget="textarea"/>
							</group>
						</page>
						
						<page string="Historia">
							<field name="message" widget="html"/>
							<field name="message_ids" widget="mail_thread"/>
						</page>

					</notebook>
				</sheet>
		       	<chatter />
			</form>
		</field>
	</record>

	<!-- ==============================================================
		 AKCJA OKNA
		 ============================================================== -->
	<record id="action_communication_logs" model="ir.actions.act_window">
		<field name="name">Logi komunikacji</field>
		<field name="res_model">communication.log</field>
		<field name="view_mode">list,form</field>
		<!--field name="search_view_id" ref="view_communication_log_search"/-->
		<field name="help" type="html">
			<p>Rejestr komunikacji eksportu/importu dokumentów.</p>
		</field>
	</record>

</odoo>
