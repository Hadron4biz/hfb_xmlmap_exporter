<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<template id="report_ksef_upo">
		<t t-call="web.external_layout">
			<main>
				<div class="page" style="font-size: 11pt; font-family: Arial, sans-serif;">

					<!-- ================================================= -->
					<!-- NAGŁÓWEK - KSeF -->
					<!-- ================================================= -->
					<div style="text-align: center; margin-bottom: 25px;">
						<div style="font-size: 14pt; font-weight: bold; color: #000;">
							Krajowy System e-Faktur
						</div>
						<div style="font-size: 11pt; margin-top: 10px; color: #333;">
							<strong>Nazwa pełna podmiotu, któremu doręczono dokument elektroniczny:</strong><br/>
							<span t-esc="upo.get('nazwa_podmiotu') or 'Ministerstwo Finansów'"/>
						</div>
						<div style="font-size: 11pt; margin-top: 5px; color: #666;">
							Informacja o dokumencie: Dokument został zarejestrowany w systemie teleinformatycznym Ministerstwa Finansów
						</div>
					</div>

					<!-- ================================================= -->
					<!-- TYTUŁ GŁÓWNY -->
					<!-- ================================================= -->
					<div style="text-align: center; font-size: 12pt; font-weight: bold; 
							   margin: 20px 0; padding: 8px; background-color: #f5f5f5; 
							   border: 1px solid #ddd;">
						Urzędowe poświadczenie odbioru dokumentu elektronicznego KSeF
					</div>

					<!-- ================================================= -->
					<!-- TABELA 1: INFORMACJE O SESJI I KONTEXCIE -->
					<!-- ================================================= -->
					<div style="margin-bottom: 20px;">
						<table style="width: 100%; border-collapse: collapse; border: 1px solid #000; font-size: 9pt;">
							<thead>
								<tr style="background-color: #f0f0f0;">
									<th colspan="2" style="border: 1px solid #000; padding: 8px; text-align: left; font-size: 10pt;">
										Informacje o sesji i kontekście
									</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td style="width: 45%; border: 1px solid #000; padding: 6px 8px;">
										<strong>Numer referencyjny sesji:</strong>
									</td>
									<td style="border: 1px solid #000; padding: 6px 8px; font-family: monospace;">
										<t t-esc="upo.get('numer_sesji') or '-'"/>
									</td>
								</tr>
								<tr>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<strong>Strona dokumentu UPO:</strong>
									</td>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<t t-esc="upo.get('strona') or '1'"/>
									</td>
								</tr>
								<tr>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<strong>Całkowita liczba stron dokumentu UPO:</strong>
									</td>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<t t-esc="upo.get('liczba_stron') or '1'"/>
									</td>
								</tr>
								<tr>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<strong>Zakres dokumentów od:</strong>
									</td>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<t t-esc="upo.get('zakres_od') or '1'"/>
									</td>
								</tr>
								<tr>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<strong>Zakres dokumentów do:</strong>
									</td>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<t t-esc="upo.get('zakres_do') or '1'"/>
									</td>
								</tr>
								<tr>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<strong>Całkowita liczba dokumentów:</strong>
									</td>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<t t-esc="upo.get('liczba_dokumentow') or '1'"/>
									</td>
								</tr>
								<tr>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<strong>Typ kontekstu:</strong>
									</td>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										NIP
									</td>
								</tr>
								<tr>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<strong>Identyfikator kontekstu uwierzytelnienia:</strong>
									</td>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<t t-esc="upo.get('nip') or '-'"/>
									</td>
								</tr>
								<tr>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<strong>Skrót dokumentu uwierzytelniającego:</strong>
									</td>
									<td style="border: 1px solid #000; padding: 6px 8px; font-family: monospace; font-size: 8pt; word-break: break-all;">
										<t t-esc="upo.get('skrot_uwierzytelniajacy') or '-'"/>
									</td>
								</tr>
								<tr>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<strong>Nazwa pliku XSD struktury logicznej:</strong>
									</td>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<t t-esc="upo.get('nazwa_struktury') or '-'"/>
									</td>
								</tr>
								<tr>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<strong>Kod formularza przedłożonego dokumentu:</strong>
									</td>
									<td style="border: 1px solid #000; padding: 6px 8px;">
										<t t-esc="upo.get('kod_formularza') or '-'"/>
									</td>
								</tr>
							</tbody>
						</table>
					</div>

					<!-- ================================================= -->
					<!-- TABELA 2: DANE DOKUMENTU (FAKTURY) -->
					<!-- ================================================= -->
					<div style="margin-bottom: 20px;">
						<table style="width: 100%; border-collapse: collapse; border: 1px solid #000; font-size: 9pt;">
							<thead>
								<tr style="background-color: #f0f0f0;">
									<th colspan="8" style="border: 1px solid #000; padding: 8px; text-align: left; font-size: 10pt;">
										Dane dokumentu (faktury)
									</th>
								</tr>
								<tr style="background-color: #f8f8f8; font-weight: bold;">
									<th style="border: 1px solid #000; padding: 6px 4px; text-align: center; width: 5%;">Lp.</th>
									<th style="border: 1px solid #000; padding: 6px 4px; text-align: left;">Numer identyfikujący fakturę w KSeF</th>
									<th style="border: 1px solid #000; padding: 6px 4px; text-align: left;">Numer faktury</th>
									<th style="border: 1px solid #000; padding: 6px 4px; text-align: left;">NIP Sprzedawcy</th>
									<th style="border: 1px solid #000; padding: 6px 4px; text-align: left;">Data wystawienia faktury</th>
									<th style="border: 1px solid #000; padding: 6px 4px; text-align: left;">Data przesłania do KSeF</th>
									<th style="border: 1px solid #000; padding: 6px 4px; text-align: left;">Data nadania numeru KSeF</th>
									<th style="border: 1px solid #000; padding: 6px 4px; text-align: left;">Tryb wysyłki</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td style="border: 1px solid #000; padding: 6px 4px; text-align: center;">1</td>
									<td style="border: 1px solid #000; padding: 6px 4px; font-family: monospace;">
										<t t-esc="upo.get('numer_ksef') or '-'"/>
									</td>
									<td style="border: 1px solid #000; padding: 6px 4px;">
										<t t-esc="upo.get('numer_faktury') or '-'"/>
									</td>
									<td style="border: 1px solid #000; padding: 6px 4px;">
										<t t-esc="upo.get('nip_sprzedawcy') or '-'"/>
									</td>
									<td style="border: 1px solid #000; padding: 6px 4px;">
										<!-- Data wystawienia bez czasu -->
										<span t-esc="upo.get('data_wystawienia') or '-'"/>
									</td>
									<td style="border: 1px solid #000; padding: 6px 4px;">
										<!-- Data przesłania z czasem -->
										<span t-esc="upo.get('data_przeslania') or '-'"/>
									</td>
									<td style="border: 1px solid #000; padding: 6px 4px;">
										<!-- Data nadania z czasem -->
										<span t-esc="upo.get('data_nadania_ksef') or '-'"/>
									</td>
									<td style="border: 1px solid #000; padding: 6px 4px;">
										<t t-esc="upo.get('tryb_wysylki') or '-'"/>
									</td>
								</tr>
							</tbody>
						</table>
					</div>

					<!-- ================================================= -->
					<!-- WARTOŚĆ FUNKCJI SKRÓTU -->
					<!-- ================================================= -->
					<div style="margin-bottom: 15px;">
						<table style="width: 100%; border-collapse: collapse; border: 1px solid #000; font-size: 9pt;">
							<tr>
								<td style="width: 25%; border: 1px solid #000; padding: 6px 8px; background-color: #f8f8f8;">
									<strong>Wartość funkcji skrótu złożonego dokumentu:</strong>
								</td>
								<td style="border: 1px solid #000; padding: 6px 8px; font-family: monospace; font-size: 8pt; word-break: break-all;">
									<t t-esc="upo.get('skrot_dokumentu') or '-'"/>
								</td>
							</tr>
						</table>
					</div>

					<!-- ================================================= -->
					<!-- PODPIS ELEKTRONICZNY (OPCJONALNIE) -->
					<!-- ================================================= -->
					<div style="margin-bottom: 20px; page-break-inside: avoid;">
						<div style="font-weight: bold; margin-bottom: 5px; font-size: 10pt;">
							Podpis elektroniczny
						</div>
						<table style="width: 100%; border-collapse: collapse; font-size: 8pt;">
							<tr>
								<td style="width: 20%; padding: 4px 0;"><strong>Czas podpisania:</strong></td>
								<td style="padding: 4px 0;"><t t-esc="upo.get('signing_time') or '-'"/></td>
							</tr>
							<tr>
								<td style="padding: 4px 0;"><strong>Wystawca certyfikatu:</strong></td>
								<td style="padding: 4px 0;"><t t-esc="upo.get('cert_issuer') or '-'"/></td>
							</tr>
							<tr>
								<td style="padding: 4px 0;"><strong>Numer seryjny certyfikatu:</strong></td>
								<td style="padding: 4px 0; font-family: monospace;"><t t-esc="upo.get('cert_serial') or '-'"/></td>
							</tr>
							<tr>
								<td style="padding: 4px 0;"><strong>Skrót (Digest):</strong></td>
								<td style="padding: 4px 0; font-family: monospace; font-size: 7pt; word-break: break-all;">
									<t t-esc="upo.get('digest_value') or '-'"/>
								</td>
							</tr>
							<tr>
								<td style="padding: 4px 0;"><strong>Wartość podpisu:</strong></td>
								<td style="padding: 4px 0; font-family: monospace; font-size: 7pt; word-break: break-all;">
									<t t-esc="upo.get('signature_value') or '-'"/>
								</td>
							</tr>
						</table>
					</div>

					<!-- ================================================= -->
					<!-- STOPKA -->
					<!-- ================================================= -->
					<div style="font-size: 8pt; color: #666; border-top: 1px solid #ddd; padding-top: 10px; margin-top: 20px;">
						<div style="text-align: center;">
							Dokument wygenerowany automatycznie na podstawie pliku UPO KSeF.<br/>
							Oryginalny plik UPO stanowi jedyną prawnie wiążącą wersję dokumentu.
						</div>
						<div style="text-align: right; margin-top: 5px;">
							<strong>Wygenerowano:</strong> <span t-esc="datetime.datetime.now().strftime('%d.%m.%Y %H:%M:%S')"/>
						</div>
					</div>

				</div>
			</main>
		</t>
	</template>


	<record id="action_report_ksef_upo" model="ir.actions.report">
		<field name="name">UPO KSeF</field>
		<field name="model">account.move</field>
		<field name="report_type">qweb-pdf</field>
		<field name="report_name">hfb_xmlmap_exporter.report_ksef_upo</field>
		<field name="report_file">hfb_xmlmap_exporter.report_ksef_upo</field>
		<field name="print_report_name">
			'upo_%s' % (object.ksef_number or object.name)
		</field>
	</record>

</odoo>
