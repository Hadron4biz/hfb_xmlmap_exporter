@startuml
title KSeF API v2 – Uwierzytelnienie (logika referencyjna)

start

:POST /auth/challenge;

if ("Wybór metody uwierzytelnienia") then (XAdES)

    :POST /auth/xades-signature;
    note right
      Otrzymujesz:
      - referenceNumber (ID sesji)
      - authenticationToken
    end note

else (Token KSeF)

    :POST /auth/ksef-token;
    note right
      Otrzymujesz:
      - referenceNumber (ID sesji)
      - authenticationToken
    end note

endif

if ("Strategia klienta") then (Bezpośredni redeem)

    :POST /auth/token/redeem
    Authorization: Bearer authenticationToken;

else (Polling statusu)

    repeat
        :GET /auth/{referenceNumber};
    repeat while (status.code == IN_PROGRESS)

    if (status.code != FINISHED_SUCCESS) then (błąd)
        :Obsługa błędu
        (np. brak uprawnień,\nunieważniony certyfikat);
        stop
    endif

    :POST /auth/token/redeem
    Authorization: Bearer authenticationToken;

endif

if ("Redeem zakończony sukcesem?") then (Tak)

    :Otrzymujesz:
    - accessToken
    - refreshToken;

    :Używaj accessToken w API;

    if ("accessToken wygasł?") then (Tak)
        :POST /auth/token/refresh
        Authorization: Bearer refreshToken;
        :Nowy accessToken;
    endif

    stop

else (Nie)

    :Obsługa błędu końcowego
    (np. certyfikat unieważniony);
    stop

endif

@enduml

